class Solution:
    def maxLength(self, arr):
        prefix_sum = 0
        max_len = 0
        d = {}

        for i in range(len(arr)):
            prefix_sum += arr[i]

            if prefix_sum == 0:
                max_len = i + 1

            if prefix_sum in d:
                max_len = max(max_len, i - d[prefix_sum])
            else:
                d[prefix_sum] = i

        return max_len
